{
  "name": "agroerp-backend-crm",
  "version": "1.0.0",
  "private": true,
  "description": "AgroERP Backend CRM — PERN stack (Fastify + PostgreSQL + Node.js + Redis) with GraphQL and AWS utilities",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "nodemon",
    "start": "node --env-file=.env src/server.js",
    "db:setup": "node scripts/db-setup.js",
    "db:seed": "node scripts/seed.js",
    "lint": "eslint .",
    "test": "node --test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.0",
    "@aws-sdk/client-ses": "^3.658.0",
    "@aws-sdk/s3-request-presigner": "^3.658.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/sensible": "^6.0.1",
    "@pinecone-database/pinecone": "^7.2.0",
    "bcryptjs": "^2.4.3",
    "close-with-grace": "^2.1.0",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "firebase-admin": "^13.0.1",
    "graphql": "^16.9.0",
    "ioredis": "^5.4.1",
    "mercurius": "^16.0.1",
    "nodemailer": "^6.9.16",
    "pg": "^8.13.1",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "eslint": "^9.13.0",
    "nodemon": "^3.1.7",
    "pino-pretty": "^11.3.0"
  }
}
