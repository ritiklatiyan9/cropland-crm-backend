# ─────────────────────────────────────────────────────────────
# AgroERP Backend CRM — Environment Configuration
# Copy this file to `.env` and fill in the values.
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=info
# Comma-separated list of allowed CORS origins (Admin CRM frontend)
CORS_ORIGINS=http://localhost:5173

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agroerp
PGSSL=false
PG_POOL_MAX=10

# Redis (sessions, cache, queues)
REDIS_URL=redis://localhost:6379

# JWT auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# AWS (S3 document storage: COA, MSDS, complaint photos, invoices)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=agroerp-documents
AWS_S3_PUBLIC_BASE_URL=
# Optional: SES sender for transactional email
AWS_SES_FROM_EMAIL=no-reply@agroerp.example

# Email — Nodemailer SMTP (Notification Center). Leave blank to disable email.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Cropland CRM <no-reply@cropland.example>

# Firebase Cloud Messaging — Farmer App push. Leave blank to disable push.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the service-account private key with literal \n for newlines.
FIREBASE_PRIVATE_KEY=

# Third-party (placeholders for later phases — see PRD §12)
# AI Crop Doctor — Gemini powers embeddings (text-embedding-004) AND diagnosis generation.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# Pinecone — managed vector store for Train AI Doctor RAG retrieval.
PINECONE_API_KEY=
PINECONE_INDEX=crop-doctor
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_NAMESPACE=training
OPENWEATHER_API_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
MSG91_AUTH_KEY=
